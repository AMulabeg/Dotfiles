exec dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec systemctl --user import-environment DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

set $mod Mod4
set $wallpaper ~/.config/wallpapers/thinkpad.png

set $term kitty
set $browser chromium


exec xss-lock -- swaylock

exec --no-startup-id dex --autostart --environment sway
exec --no-startup-id wlsunset -l 52.48 -L 13.43
exec --no-startup-id autotiling
exec --no-startup-id waybar


font pango:JetBrains Mono NF 15

for_window [class="^.*"] border pixel 2
client.focused #FFFFFF #FFFFFF #000000 #FFFFFF #FFFFFF
output * background $wallpaper fill


assign [app_id="firefox"] workspace number 1
assign [app_id="chromium"] workspace number 1
assign [app_id="brave"] workspace number 1
assign [app_id="zapzap"] workspace number 3
assign [app_id="vesktop"] workspace number 4
assign [instance="spotify"] workspace number 5
assign [instance="IntelliJ"] workspace number 3

for_window [app_id="floorp"] focus
for_window [app_id="thorium-browser"] focus
for_window [app_id="zapzap"] focus
for_window [app_id="vesktop"] focus
for_window [class="Spotify"] focus
for_window [class="IntelliJ"] focus


mode "resize" {
    bindsym j resize shrink width 10 px or 10 ppt
    bindsym k resize grow height 10 px or 10 ppt
    bindsym l resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow width 10 px or 10 ppt

    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

include ./keybindings
include ./inputs


